# --- Google Gemini (required) ---------------------------------------------
# Your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"
# Multimodal model to use (must support image input).
GEMINI_MODEL=gemini-3.5-flash

# --- Data sources (optional overrides) -------------------------------------
# Page to scrape the surface-pressure chart from.
PRESSURE_CHART_URL=https://weather.metoffice.gov.uk/maps-and-charts/surface-pressure
# If the app cannot auto-locate the chart image on the page, set a direct
# image URL here to make downloads deterministic.
PRESSURE_CHART_IMAGE_URL=
# Meteomar bulletin page.
METEOMAR_URL=https://www.meteoam.it/it/messaggio-meteomar

# --- Headless-browser fallback (optional) ----------------------------------
# When static scraping cannot find the JS-rendered chart, render the page with
# Playwright (Chromium) and screenshot it. Set to false to disable.
USE_PLAYWRIGHT_FALLBACK=true
# Max time (ms) to wait for the page to render.
PLAYWRIGHT_TIMEOUT_MS=45000

# --- Report tuning (optional) ----------------------------------------------
# Navigation areas the report should focus on.
NAV_AREAS=Arcipelago di La Maddalena e Caprera (Sardegna nord-orientale) - zone Meteomar di riferimento: Mar di Sardegna, Mar di Corsica e Tirreno Settentrionale
# Max output tokens for the generated report.
MAX_TOKENS=16000

# --- Scheduling (optional) --------------------------------------------------
# How often to run the pipeline, in hours.
RUN_INTERVAL_HOURS=6
# Run immediately on container start (true/false).
RUN_ON_START=true

# --- Logging (optional) -----------------------------------------------------
LOG_LEVEL=INFO

# Budget di ragionamento del modello (-1=default dinamico, 0=disattiva, N=cap token)
GEMINI_THINKING_BUDGET=-1
